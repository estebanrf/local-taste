# Part 6: Local Taste Agent Configuration
# Copy to terraform.tfvars and fill in your values

aws_region = "eu-west-1"

# Aurora cluster ARN from Part 5 (run: cd terraform/5_database && terraform output)
aurora_cluster_arn = "arn:aws:rds:eu-west-1:123456789012:cluster:localtaste-aurora-cluster"

# Aurora secret ARN from Part 5
aurora_secret_arn = "arn:aws:secretsmanager:eu-west-1:123456789012:secret:localtaste-aurora-credentials-xxxxx"

# Bedrock model - Nova Pro recommended
bedrock_model_id = "us.amazon.nova-pro-v1:0"

# Bedrock region (eu-west-1 has broadest model availability)
bedrock_region = "eu-west-1"

# LangFuse observability (optional - configure in Part 8)
# langfuse_public_key = "pk-lf-..."
# langfuse_secret_key = "sk-lf-..."
# langfuse_host       = "https://us.cloud.langfuse.com"

# OpenAI API key (needed for OpenAI Agents SDK tracing - no spend required)
# openai_api_key = ""

# Google Maps API key for Places search in Restaurant Ranker
google_maps_api_key = "AIza..."
